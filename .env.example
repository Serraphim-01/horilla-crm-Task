# Django
DJANGO_SETTINGS_MODULE=horilla.settings
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=*

# Database (used by compose to form DATABASE_URL)
POSTGRES_DB=horilla
POSTGRES_USER=horilla
POSTGRES_PASSWORD=horilla

# Redis Cache
REDIS_PASSWORD=horilla
REDIS_URL=redis://:horilla@redis:6379/0

# Celery (CRM uses Celery for automations, scheduled exports, mail)
CELERY_BROKER_URL=redis://:horilla@redis:6379/0
CELERY_RESULT_BACKEND=redis://:horilla@redis:6379/0

# Optional: storage/other
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# Microsoft SSO (Optional)
# To enable Microsoft SSO, uncomment and configure these values:
# MICROSOFT_SSO_ENABLED=True
# MICROSOFT_SSO_CLIENT_ID=your_azure_ad_client_id
# MICROSOFT_SSO_CLIENT_SECRET=your_azure_ad_client_secret
# MICROSOFT_SSO_TENANT_ID=your_tenant_id_or_common
# MICROSOFT_SSO_AUTO_PROVISION=True
